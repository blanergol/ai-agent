# Runtime mode
AGENT_CORE_MODE=dev

# LLM
AGENT_CORE_LLM_PROVIDER=openai
AGENT_CORE_LLM_MODEL=gpt-4o-mini
AGENT_CORE_LLM_BASE_URL=
AGENT_CORE_LLM_OPENAI_API_KEY=
AGENT_CORE_LLM_OPENROUTER_API_KEY=
AGENT_CORE_LLM_OPENROUTER_HTTP_REFERER=
AGENT_CORE_LLM_OPENROUTER_APP_TITLE=agent-core-local
AGENT_CORE_LLM_TEMPERATURE=0
AGENT_CORE_LLM_TOP_P=1
AGENT_CORE_LLM_SEED=0
AGENT_CORE_LLM_MAX_OUTPUT_TOKENS=1024
AGENT_CORE_LLM_TIMEOUT_MS=20000
AGENT_CORE_LLM_MAX_RETRIES=2
AGENT_CORE_LLM_RETRY_BASE_MS=300
AGENT_CORE_LLM_MAX_PARALLEL=4
AGENT_CORE_LLM_CIRCUIT_BREAKER_FAILURES=5
AGENT_CORE_LLM_CIRCUIT_BREAKER_COOLDOWN_MS=10000
AGENT_CORE_LLM_DISABLE_JITTER=false

# Memory
AGENT_CORE_MEMORY_SHORT_TERM_MAX_MESSAGES=20
AGENT_CORE_MEMORY_RECALL_TOP_K=5
AGENT_CORE_MEMORY_TOKEN_BUDGET=2048

# Planner
AGENT_CORE_PLANNER_MAX_STEPS=8
AGENT_CORE_PLANNER_MAX_PLANNING_RETRIES=2
AGENT_CORE_PLANNER_ACTION_JSON_RETRIES=2

# Tools
AGENT_CORE_TOOLS_ALLOWLIST=time.now,kv.put,kv.get,http.get
AGENT_CORE_TOOLS_DENYLIST=
AGENT_CORE_TOOLS_DEFAULT_TIMEOUT_MS=5000
AGENT_CORE_TOOLS_MAX_EXECUTION_RETRIES=1
AGENT_CORE_TOOLS_MAX_PARALLEL=16
AGENT_CORE_TOOLS_DEDUP_TTL_MS=600000
AGENT_CORE_TOOLS_MAX_OUTPUT_BYTES=65536
AGENT_CORE_TOOLS_HTTP_ALLOW_DOMAINS=example.com,api.github.com
AGENT_CORE_TOOLS_HTTP_MAX_BODY_BYTES=65536
AGENT_CORE_TOOLS_HTTP_TIMEOUT_MS=5000

# MCP
AGENT_CORE_MCP_ENABLED=false
# JSON format example:
# AGENT_CORE_MCP_SERVERS=[{"name":"local","base_url":"http://localhost:8787","enabled":true,"token":""}]
# KV format example:
# AGENT_CORE_MCP_SERVERS=name=local,base_url=http://localhost:8787,enabled=true
AGENT_CORE_MCP_SERVERS=

# State
AGENT_CORE_STATE_PERSIST_PATH=

# Agent / guardrails
AGENT_CORE_AGENT_MAX_STEP_DURATION_MS=20000
AGENT_CORE_AGENT_CONTINUE_ON_TOOL_ERROR=true
AGENT_CORE_AGENT_MAX_INPUT_CHARS=8000
AGENT_CORE_AGENT_DETERMINISTIC=false
AGENT_CORE_BUNDLE_ENABLED=false
AGENT_CORE_GUARDRAILS_MAX_STEPS=8
AGENT_CORE_GUARDRAILS_MAX_TOOL_CALLS=8
AGENT_CORE_GUARDRAILS_MAX_TIME_MS=120000
AGENT_CORE_GUARDRAILS_MAX_TOOL_OUTPUT_BYTES=65536

# Output validation
AGENT_CORE_OUTPUT_MAX_CHARS=8000
AGENT_CORE_OUTPUT_FORBIDDEN_SUBSTRINGS=
AGENT_CORE_OUTPUT_VALIDATION_RETRIES=1

# Auth / logging / skills
AGENT_CORE_AUTH_USER_AUTH_HEADER=X-User-Sub
AGENT_CORE_LOGGING_DEBUG=false
AGENT_CORE_LOGGING_VERBOSE_TRACING=false
AGENT_CORE_LOGGING_DEBUG_ARTIFACTS=false
AGENT_CORE_LOGGING_DEBUG_ARTIFACTS_MAX_CHARS=2000
AGENT_CORE_SKILLS=ops

# Web UI (one-page tester at / and /ui)
AGENT_CORE_WEB_UI_ENABLED=true

# Langfuse (agent-native OTLP integration)
AGENT_CORE_LANGFUSE_ENABLED=false
AGENT_CORE_LANGFUSE_HOST=http://langfuse-web:3000
AGENT_CORE_LANGFUSE_PUBLIC_KEY=lf_pk_default_public_key
AGENT_CORE_LANGFUSE_SECRET_KEY=lf_sk_default_secret_key
AGENT_CORE_LANGFUSE_TIMEOUT_MS=10000
AGENT_CORE_LANGFUSE_SERVICE_NAME=agent-core
AGENT_CORE_LANGFUSE_SERVICE_VERSION=
AGENT_CORE_LANGFUSE_ENVIRONMENT=dev
# JSON map model -> pricing in USD per 1M tokens (fallback when provider does not return native costs)
# AGENT_CORE_LANGFUSE_MODEL_PRICES={"openai/gpt-4o-mini":{"input_per_1m":0.15,"output_per_1m":0.6}}
AGENT_CORE_LANGFUSE_MODEL_PRICES=

# Langfuse SDK defaults for app containers
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_PUBLIC_KEY=lf_pk_default_public_key
LANGFUSE_SECRET_KEY=lf_sk_default_secret_key

# Langfuse self-host bootstrap defaults (docker-compose.observability.yml)
LANGFUSE_INIT_ORG_ID=default-org
LANGFUSE_INIT_ORG_NAME=Default Organization
LANGFUSE_INIT_PROJECT_ID=default-project
LANGFUSE_INIT_PROJECT_NAME=Default Project
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=lf_pk_default_public_key
LANGFUSE_INIT_PROJECT_SECRET_KEY=lf_sk_default_secret_key
LANGFUSE_INIT_USER_EMAIL=admin@local.dev
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=adminadmin
LANGFUSE_DEFAULT_ORG_ID=default-org
LANGFUSE_DEFAULT_ORG_ROLE=OWNER
LANGFUSE_DEFAULT_PROJECT_ID=default-project
LANGFUSE_DEFAULT_PROJECT_ROLE=OWNER

# Secret fallbacks
OPENAI_API_KEY=
OPENROUTER_API_KEY=
# MCP_TOKEN_<SERVER_NAME>=
